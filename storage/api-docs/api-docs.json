{
    "openapi": "3.0.0",
    "info": {
        "title": "Search Inside a Book API",
        "description": "API for searching inside books with Meilisearch integration. Provides powerful full-text search, caching, and health monitoring capabilities.",
        "contact": {
            "name": "API Support",
            "email": "support@example.com"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0.0",
        "x-logo": {
            "url": "https://laravel.com/img/logomark.min.svg"
        }
    },
    "servers": [
        {
            "url": "http://my-default-host.com",
            "description": "API Server"
        }
    ],
    "paths": {
        "/api": {}
    },
    "components": {
        "schemas": {
            "Error": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Resource not found"
                    },
                    "status": {
                        "type": "integer",
                        "example": 404
                    }
                },
                "type": "object"
            },
            "ValidationError": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The given data was invalid."
                    },
                    "errors": {
                        "properties": {
                            "q": {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "example": "The search query is required."
                                }
                            }
                        },
                        "type": "object"
                    }
                },
                "type": "object"
            }
        }
    }
}